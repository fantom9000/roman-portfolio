---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Divider from "@components/Divider.astro";
import HeroText from "@components/HeroText.astro";
import ProjectPreview from "@components/ProjectPreview.astro";
import { projects, sideWork } from "@data/projects";
---

<BaseLayout>
  <main class="page">
    <Header />
    <HeroText
      indent
      text="В дизайне с 2023 года, работал в Бюро Горбунова. Проектировал интерфейсы для Peptid.ru, SayGames, Mary Trufel и «Welcome Доставка», использую 3D и AI-инструменты."
    />
    <Divider />
    <section class="projects-list" aria-label="Проекты">
      {projects.slice(0, 2).map((project) => <ProjectPreview project={project} />)}
      <HeroText
        indent
        text="Адепт подходов бюро: ФФФ, инфостиль Ильяхова и интерфейсные принципы Бирмана. Люблю дизайн-системы, глубоко погружаюсь в задачи и ищу системные решения."
      />
      {projects.slice(2).map((project) => <ProjectPreview project={project} />)}
    </section>
    <section class="welcome-work" aria-label="Welcome доставка">
      <div class="welcome-work__phones" aria-label="Экраны приложения Welcome доставка">
        {
          [
            ["welcome-1.png", "Главный экран Welcome доставки"],
            ["welcome-2.png", "Экран каталога Welcome доставки"],
            ["welcome-3.png", "Экран карточки блюда Welcome доставки"],
            ["welcome-4.png", "Экран оформления заказа Welcome доставки"],
            ["welcome-5.png", "Экран профиля Welcome доставки"]
          ].map(([image, alt]) => (
            <figure class="welcome-phone">
              <img src={`/images/figma/high/welcome/${image}`} alt={alt} loading="lazy" />
            </figure>
          ))
        }
      </div>
      <div class="welcome-work__text">
        <h2>Welcome доставка</h2>
        <p>
          Полный редизайн мобильного приложения сервиса доставки еды. Добавлены тематические модули
          с подборками и акциями, переработаны фильтры, обновлены карточки ресторанов.
        </p>
        <p>
          Собрана новая структура страницы: добавлены перебивки с фактами и предложениями,
          разработан дизайн тематических подборок и система навигации по категориям.
        </p>
      </div>
    </section>
    <Divider />
    <section class="side-work">
      <aside class="side-work__text">
        <h2>{sideWork.concepts.title}</h2>
        <p>{sideWork.concepts.description}</p>
      </aside>
      <div class="concepts-grid" aria-label="Концепты">
        <div class="concepts-left">
          <div class="concepts-top">
            <figure class="concept-widgets"><img src="/images/figma/high/concepts/concept-widgets.webp" alt="Концепт виджетов" loading="lazy" /></figure>
            <div class="concepts-center">
              <figure class="concept-ar"><img src="/images/figma/high/concepts/concept-ar.webp" alt="Концепт AR" loading="lazy" /></figure>
              <figure class="concept-bereal"><img src="/images/figma/high/concepts/concept-bereal.webp" alt="Концепт BeReal" loading="lazy" /></figure>
            </div>
          </div>
          <div class="concepts-bottom">
            <figure class="concept-outdoor"><img src="/images/figma/high/concepts/concept-outdoor.webp" alt="Концепт Outdoor" loading="lazy" /></figure>
            <figure class="concept-finance"><img src="/images/figma/high/concepts/concept-finance.webp" alt="Концепт Finance" loading="lazy" /></figure>
          </div>
        </div>
        <div class="concepts-right">
          <figure class="concept-tripadvisor"><img src="/images/figma/high/concepts/concept-tripadvisor.webp" alt="Концепт Tripadvisor" loading="lazy" /></figure>
          <figure class="concept-city"><img src="/images/figma/high/concepts/concept-city.webp" alt="Концепт City Guide" loading="lazy" /></figure>
        </div>
      </div>
    </section>
    <Divider />
    <section class="side-work side-work--tall">
      <aside class="side-work__text">
        <h2>{sideWork.threeD.title}</h2>
        <p>{sideWork.threeD.description}</p>
      </aside>
      <div class="three-d-grid" aria-label="3D работы">
        <figure class="three-d-tile three-d-tile--wide">
          <img src="/images/figma/high/three-d-tiles/santa.png" alt="Иллюстрация для концепции приложения-компаньона Санта Клауса" loading="lazy" />
        </figure>
        <figure class="three-d-tile">
          <img src="/images/figma/high/three-d-tiles/heart.png" alt="3D-график просмотров" loading="lazy" />
        </figure>
        <figure class="three-d-tile">
          <img src="/images/figma/high/three-d-tiles/paper.png" alt="3D-иллюстрация бумажной формы" loading="lazy" />
        </figure>
        <figure class="three-d-tile three-d-tile--wide">
          <img src="/images/figma/high/three-d-tiles/bereal.png" alt="Шот для концепции редизайна приложения BeReal" loading="lazy" />
        </figure>
        <figure class="three-d-tile three-d-tile--wide three-d-tile--car">
          <img src="/images/figma/high/three-d-tiles/f1-car.png" alt="3D-концепт гоночного автомобиля" loading="lazy" />
        </figure>
        <figure class="three-d-tile">
          <img src="/images/figma/high/three-d-tiles/sber.png" alt="3D-концепт для интерфейса" loading="lazy" />
        </figure>
        <figure class="three-d-tile">
          <img src="/images/figma/high/three-d-tiles/icecream.png" alt="3D-иллюстрация мороженого" loading="lazy" />
        </figure>
      </div>
    </section>
    <Footer />
  </main>
</BaseLayout>
