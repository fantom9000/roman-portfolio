---
import { site } from "@data/site";
---

<header class="site-header text-20">
  <a class="site-name" href="/" aria-label="На главную">{site.name}</a>
  <span class="site-role">{site.title}</span>
  <nav class="contact-links" aria-label="Контакты">
    <a href={site.contacts.cv}>CV</a>
    <a href={site.contacts.telegram}>Телеграм</a>
    <a href={site.contacts.email}>Почта</a>
  </nav>
</header>
